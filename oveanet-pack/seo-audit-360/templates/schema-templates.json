{
  "_comment": "TEMPLATE — Schema.org JSON-LD Templates for SEO/GEO Optimization",
  "_instructions": "Copy the relevant schema types into your page's <head> as <script type='application/ld+json'>. Replace [BRACKETS] with actual values.",

  "ProfessionalService": {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "[Company Name]",
    "url": "https://[your-domain.com]",
    "logo": "https://[your-domain.com]/logo.svg",
    "image": "https://[your-domain.com]/og.jpg",
    "description": "[Company description — 1-2 sentences]",
    "founder": {
      "@type": "Person",
      "name": "[Founder Name]",
      "url": "[Founder LinkedIn URL]"
    },
    "sameAs": ["[LinkedIn URL]", "[Twitter URL]", "[GitHub URL]"],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "[City]",
      "postalCode": "[Postal Code]",
      "addressRegion": "[Region]",
      "addressCountry": "[Country Code]"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 0.0,
      "longitude": 0.0
    },
    "areaServed": [
      { "@type": "Country", "name": "[Country]" },
      { "@type": "Place", "name": "International" }
    ],
    "knowsAbout": ["[Skill 1]", "[Skill 2]", "[Skill 3]"],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "[Service 1]",
            "description": "[Service 1 description]"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "[Service 2]",
            "description": "[Service 2 description]"
          }
        }
      ]
    }
  },

  "FAQPage": {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "[Question 1]?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "[Answer 1]"
        }
      },
      {
        "@type": "Question",
        "name": "[Question 2]?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "[Answer 2]"
        }
      }
    ]
  },

  "WebPage": {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "[Page Title]",
    "url": "https://[your-domain.com]/",
    "datePublished": "[YYYY-MM-DD]",
    "dateModified": "[YYYY-MM-DD]",
    "inLanguage": ["en", "fr"],
    "isPartOf": {
      "@type": "WebSite",
      "name": "[Site Name]",
      "url": "https://[your-domain.com]/"
    }
  },

  "BreadcrumbList": {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://[your-domain.com]/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "[Page Name]",
        "item": "https://[your-domain.com]/[page]"
      }
    ]
  }
}
